# ── SPC Website — Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.

# ── Contact form → email notifications ───────────────────────────────────

# Where to receive inquiry emails (your inbox)
NOTIFY_EMAIL=jv.steelpipe@gmail.com

# Gmail SMTP — leave host/port as-is for Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# The Gmail account that SENDS the notification emails
SMTP_USER=jv.steelpipe@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
SMTP_PASS=
